{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevCenter",
  "version": "0.1.0",
  "identifier": "com.devcenter.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "splashscreen",
        "url": "splash.html",
        "title": "DevCenter",
        "width": 440,
        "height": 280,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "skipTaskbar": true,
        "shadow": false,
        "alwaysOnTop": true
      },
      {
        "label": "main",
        "title": "DevCenter",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/BipulRaman/DevCenter/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Track repos, PRs and local apps",
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
