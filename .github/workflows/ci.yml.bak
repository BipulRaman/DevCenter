name: CI

# Verify the app compiles on every commit and pull request that touches the app.
# `branches: ['**']` matches all branch pushes but NOT tag pushes, so creating a
# release (which pushes a tag) doesn't trigger CI — the Release workflow already
# builds every OS for that tag.
# `paths` limits CI to changes under app/ — edits to docs, README, scripts or
# other workflows don't affect compilation, so they skip the build.
on:
  push:
    branches: ['**']
    paths: ['app/**']
  pull_request:
    paths: ['app/**']

# Cancel an in-progress run when new commits are pushed to the same ref.
concurrency:
  group: ci-${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  build:
    name: Build (${{ matrix.name }})
    strategy:
      fail-fast: false
      matrix:
        include:
          - platform: windows-latest
            name: Windows
          - platform: macos-latest
            name: macOS
          - platform: ubuntu-22.04
            name: Linux
    runs-on: ${{ matrix.platform }}
    # Incremental compilation is useless in clean CI runs and only bloats the
    # shared cache, so turn it off.
    env:
      CARGO_INCREMENTAL: "0"
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      # Tauri on Linux links against the system WebKitGTK/GTK stack at build
      # time, so those -dev packages must be present even for `cargo build`.
      - name: Install Linux build dependencies
        if: runner.os == 'Linux'
        run: |
          sudo apt-get update
          sudo apt-get install -y libwebkit2gtk-4.1-dev libappindicator3-dev librsvg2-dev patchelf libssl-dev build-essential

      - name: Install Rust (stable)
        uses: dtolnay/rust-toolchain@stable

      # Caches the cargo registry, git deps and the target/ dir so subsequent
      # runs only recompile what changed. rust-cache keys per-OS automatically;
      # only main writes the cache so PR/branch runs don't thrash it.
      - name: Cache Rust build
        uses: Swatinem/rust-cache@v2
        with:
          workspaces: app/src-tauri -> target
          key: ${{ matrix.name }}
          save-if: ${{ github.ref == 'refs/heads/main' }}

      # A plain `cargo build` runs the tauri-build script and the
      # `generate_context!` macro, which embed the frontend from ../ui — so this
      # verifies the whole desktop app compiles (frontend + backend) on each OS.
      # No Tauri CLI or npm step is needed because the UI is static (vanilla JS).
      - name: Build (verify it compiles)
        working-directory: app/src-tauri
        run: cargo build --locked
