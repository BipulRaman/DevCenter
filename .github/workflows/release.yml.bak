name: Release

# Build & publish signed installers for Windows, macOS (Apple Silicon + Intel)
# and Linux, plus the updater manifest (latest.json), to one GitHub Release.
# The OS builds run in PARALLEL; a final job then assembles latest.json from
# every platform's signature so auto-update covers all of them without the
# parallel-upload race in tauri-action's own updater-JSON step.
# Fires exactly ONCE when a GitHub Release is PUBLISHED (write your notes in the
# UI, then click "Publish release"). Manual dispatch is supported for rebuilds.
#
# Why `release: published` and not `push: tags`?
#   Publishing a release in the UI creates the tag, drafts, then publishes it,
#   which would fire push + created + published all at once -> three racing
#   builds uploading the same assets. `published` fires once.
on:
  release:
    types: [published]
  workflow_dispatch:
    inputs:
      tag:
        description: 'Tag to build and publish (e.g. v1.0.2). A release is created if missing.'
        required: true
        type: string

# Needed so tauri-action can create/update the release and upload the installer.
permissions:
  contents: write

concurrency:
  group: release-${{ github.event.release.tag_name || github.event.inputs.tag }}
  cancel-in-progress: false

jobs:
  release:
    name: ${{ matrix.name }}
    strategy:
      # Build every OS in PARALLEL. Don't cancel the others if one fails — a
      # partial release is still useful and easier to diagnose.
      fail-fast: false
      matrix:
        include:
          - platform: windows-latest
            name: Windows installer
            args: --bundles nsis --config updater.conf.json
          - platform: macos-latest
            name: macOS (Apple Silicon)
            args: --target aarch64-apple-darwin --bundles app,dmg --config updater.conf.json
          - platform: macos-latest
            name: macOS (Intel)
            args: --target x86_64-apple-darwin --bundles app,dmg --config updater.conf.json
          - platform: ubuntu-22.04
            name: Linux (AppImage + deb)
            args: --bundles appimage,deb --config updater.conf.json
    runs-on: ${{ matrix.platform }}
    # Incremental compilation is useless in clean CI runs and only bloats the
    # cache; add network retries for occasional flaky crate downloads.
    env:
      CARGO_INCREMENTAL: "0"
      CARGO_NET_RETRY: "10"
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      # Tauri on Linux links against the system WebKitGTK/GTK stack, so those
      # -dev packages must be installed before building the bundles.
      - name: Install Linux build dependencies
        if: runner.os == 'Linux'
        run: |
          sudo apt-get update
          sudo apt-get install -y libwebkit2gtk-4.1-dev libappindicator3-dev librsvg2-dev patchelf libssl-dev build-essential

      # The tag is the single source of truth for the version. Strip the leading
      # "v" (v1.0.2 -> 1.0.2) and stamp it into tauri.conf.json for this build
      # only (not committed). The app reads its version from there
      # (package_info().version), so no other file needs patching.
      - name: Resolve tag & stamp version
        id: tag
        shell: pwsh
        run: |
          $tag = if ($env:GITHUB_EVENT_NAME -eq 'workflow_dispatch') { '${{ inputs.tag }}' } else { '${{ github.event.release.tag_name }}' }
          $version = $tag -replace '^v', ''
          if ($version -notmatch '^\d+\.\d+\.\d+$') {
            throw "Tag '$tag' is not a valid version (expected vX.Y.Z)."
          }
          "tag=$tag" | Out-File -FilePath $env:GITHUB_OUTPUT -Append -Encoding utf8
          $conf = "app/src-tauri/tauri.conf.json"
          (Get-Content $conf -Raw) -replace '"version"\s*:\s*"[^"]*"', ('"version": "' + $version + '"') |
            Set-Content $conf -NoNewline -Encoding utf8
          Write-Host "Building App $version (from tag $tag)"

      - name: Install Rust (stable)
        uses: dtolnay/rust-toolchain@stable
        with:
          # Both macOS targets are installed on the macOS runners so either the
          # Apple Silicon or the Intel matrix leg can (cross-)compile.
          targets: ${{ matrix.platform == 'macos-latest' && 'aarch64-apple-darwin,x86_64-apple-darwin' || '' }}

      - name: Cache Rust build
        uses: Swatinem/rust-cache@v2
        with:
          workspaces: app/src-tauri -> target
          # Keyed per matrix leg so the OS/target builds don't overwrite each
          # other's cache (rust-cache also segments by OS automatically).
          key: ${{ matrix.name }}
      # Cache the NSIS bundler Tauri downloads on first build so later runs
      # don't re-fetch nsis-3.11.zip every time (Windows only).
      - name: Cache Tauri NSIS bundler
        if: runner.os == 'Windows'
        uses: actions/cache@v4
        with:
          path: ~\AppData\Local\tauri\NSIS
          key: tauri-nsis-v1

      # The public key is NOT committed to tauri.conf.json. Write a CI-only config
      # override (merged via --config below) that injects the pubkey from a secret
      # and enables updater-artifact creation just for this build. This file is
      # written on the runner only and is never committed.
      - name: Inject updater public key from secret
        shell: pwsh
        env:
          DC_PUBKEY: ${{ secrets.TAURI_SIGNING_PUBLIC_KEY }}
        run: |
          $pub = "$env:DC_PUBKEY".Trim()
          if (-not $pub) { throw "TAURI_SIGNING_PUBLIC_KEY secret is not set." }
          $json = '{"bundle":{"createUpdaterArtifacts":true},"plugins":{"updater":{"pubkey":"' + $pub + '"}}}'
          Set-Content -Path "app/updater.conf.json" -Value $json -NoNewline -Encoding utf8
          Write-Host "Wrote app/updater.conf.json with pubkey from secret."

      # Builds this OS's bundles and signs the updater artifacts, then attaches
      # them (+ their .sig signatures) to the release. latest.json is assembled
      # separately by the updater-manifest job once all OS builds finish.
      - name: Build, sign & publish
        uses: tauri-apps/tauri-action@v0
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          # Updater signing. The private key lives in the TAURI_SIGNING_PRIVATE_KEY
          # repo secret; the public key is injected from the TAURI_SIGNING_PUBLIC_KEY
          # secret via the --config override (see the step above) — nothing
          # key-related is committed. The password var must be DEFINED (Tauri errors
          # if it's missing) but is intentionally empty: the key has no passphrase.
          TAURI_SIGNING_PRIVATE_KEY: ${{ secrets.TAURI_SIGNING_PRIVATE_KEY }}
          TAURI_SIGNING_PRIVATE_KEY_PASSWORD: ''
        with:
          projectPath: app
          tagName: ${{ steps.tag.outputs.tag }}
          releaseName: App ${{ steps.tag.outputs.tag }}
          releaseBody: 'Automated build for ${{ steps.tag.outputs.tag }}. Installer below; existing installs update automatically.'
          releaseDraft: false
          prerelease: false
          # Each leg uploads its OWN bundles + .sig signatures but does NOT write
          # latest.json: tauri-action's updater-JSON step read-modify-writes the
          # shared latest.json asset, which races when legs run in parallel and
          # can drop a platform. The "updater-manifest" job below assembles it
          # once, after all legs finish.
          uploadUpdaterJson: false
          # Retry transient upload failures (and the rare concurrent find-or-
          # create of the release on a fresh workflow_dispatch tag).
          retryAttempts: 3
          # Per-OS bundles + the CI-only --config override (pubkey +
          # createUpdaterArtifacts) merged on top of tauri.conf.json. Relative
          # --config paths resolve against projectPath (app).
          args: ${{ matrix.args }}

  # After every OS build finishes, assemble ONE latest.json from all the
  # uploaded *.sig signatures and publish it. Doing this in a single job (rather
  # than per-leg) means the parallel builds can never race and drop a platform
  # from the updater manifest.
  updater-manifest:
    name: Publish updater manifest
    needs: release
    # Run even if some OS legs failed (fail-fast: false) so a partial release
    # still gets a manifest for the platforms that did build.
    if: ${{ !cancelled() }}
    runs-on: ubuntu-latest
    steps:
      - name: Resolve tag
        id: tag
        shell: bash
        run: |
          if [ "${{ github.event_name }}" = "workflow_dispatch" ]; then
            echo "tag=${{ inputs.tag }}" >> "$GITHUB_OUTPUT"
          else
            echo "tag=${{ github.event.release.tag_name }}" >> "$GITHUB_OUTPUT"
          fi

      - name: Assemble & upload latest.json
        shell: bash
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          GH_REPO: ${{ github.repository }}
          TAG: ${{ steps.tag.outputs.tag }}
        run: |
          set -euo pipefail
          version="${TAG#v}"
          work="$(mktemp -d)"

          # One updater signature per successfully built platform.
          mapfile -t sigs < <(gh release view "$TAG" --json assets -q '.assets[].name' | grep '\.sig$' || true)
          if [ "${#sigs[@]}" -eq 0 ]; then
            echo "::error::No '*.sig' updater signatures found on release $TAG." >&2
            exit 1
          fi

          notes="$(gh release view "$TAG" --json body -q '.body' 2>/dev/null || true)"
          platforms='{}'
          for sig in "${sigs[@]}"; do
            # Map each signature to the Tauri updater's {os}-{arch} key(s).
            case "$sig" in
              *-setup.exe.sig)                              keys="windows-x86_64"; bundle=nsis ;;
              *aarch64.app.tar.gz.sig)                      keys="darwin-aarch64"; bundle=app ;;
              *x64.app.tar.gz.sig | *x86_64.app.tar.gz.sig) keys="darwin-x86_64";  bundle=app ;;
              *.AppImage.sig)                               keys="linux-x86_64";  bundle=appimage ;;
              *) echo "Skipping unrecognized signature: $sig"; continue ;;
            esac
            asset="${sig%.sig}"
            gh release download "$TAG" --pattern "$sig" --dir "$work" --clobber
            signature="$(cat "$work/$sig")"
            url="https://github.com/$GH_REPO/releases/download/$TAG/$asset"
            entry="$(jq -n --arg s "$signature" --arg u "$url" '{signature:$s, url:$u}')"
            for key in $keys; do
              # Write the classic {os}-{arch} key plus the newer
              # {os}-{arch}-{bundle} key so any updater version resolves it.
              platforms="$(jq --arg k "$key" --arg kb "$key-$bundle" --argjson e "$entry" \
                '.[$k]=$e | .[$kb]=$e' <<<"$platforms")"
            done
          done

          jq -n \
            --arg v "$version" \
            --arg n "$notes" \
            --arg d "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            --argjson p "$platforms" \
            '{version: $v, notes: $n, pub_date: $d, platforms: $p}' > "$work/latest.json"

          echo "Assembled latest.json:"
          cat "$work/latest.json"
          gh release upload "$TAG" "$work/latest.json" --clobber
